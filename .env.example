# プロジェクトルートに .env としてコピーしてください（tauri dev 時に dotenvy が読み込みます）
OPENAI_API_KEY=sk-...

# 任意（既定: gpt-4o）
MATH_TEACHER_VISION_MODEL=gpt-4o

# 概念抽出・入力正規化（既定: gpt-4o-mini）
MATH_TEACHER_CONCEPT_MODEL=gpt-4o-mini

# Phase 3 メインQ&A（Thinking ON 時。既定: gpt-4o）
# MATH_TEACHER_MAIN_MODEL=gpt-4o
# Thinking OFF 時は高速モデル（既定: gpt-4o-mini）
# MATH_TEACHER_FAST_MODEL=gpt-4o-mini

# Poppler 画像化 DPI（日本語の細かい字向けに既定 200）
# MATH_TEACHER_PDFTOPPM_DPI=200

# Phase 4 Memory: 解決時要約モデル（未設定なら MATH_TEACHER_CONCEPT_MODEL）
# MATH_TEACHER_MEMORY_SUMMARY_MODEL=gpt-4o-mini
# RRF の k（大きいほど順位の差がなだらか）
# MATH_TEACHER_RRF_K=60
# 時間減衰 λ（1日あたり、大きいほど古いメモリが弱くなる）
# MATH_TEACHER_MEMORY_DECAY_LAMBDA=0.05
# Ruri 埋め込み時のクエリ用プレフィックス（モデル・ドキュメントに従う）
# MATH_TEACHER_RURI_QUERY_PREFIX=

# 1 または true で概念抽出をスキップ（Vision LaTeX のみ）
# MATH_TEACHER_SKIP_CONCEPTS=0

# ローカル埋め込み（sidecar/embedder.py）— 既定は多言語 E5 小型
# MATH_TEACHER_EMBED_MODEL=intfloat/multilingual-e5-small
# Ruri 例: cl-nagoya/ruri-v3-310m
